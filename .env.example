# ══════════════════════════════════════════════════════════════════════════════
# NutriAI — Environment Template
# Copy this file to `.env` and fill in your actual values.
# Never commit the real `.env` file!
# ══════════════════════════════════════════════════════════════════════════════

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=ai_diet_planner

# ── Spoonacular API ───────────────────────────────────────────────────────────
# Get your free key at: https://spoonacular.com/food-api
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# ── OpenRouter API (AI Chat) ──────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4-vision

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_random_jwt_secret_here

# ── SMTP Email (meal reminders) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_NAME=NutriAI Diet Planner

# ── Service URLs & Ports ─────────────────────────────────────────────────────
FASTAPI_PORT=8000
EXPRESS_PORT=8787
FASTAPI_BASE_URL=http://127.0.0.1:8000
APP_BASE_URL=http://localhost:5173
