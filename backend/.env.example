# ══════════════════════════════════════════════════════════════════════════════
# AI Diet & Nutrition Planner — Backend Environment (FastAPI)
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `backend/.env` and fill in your actual values.

# ── MongoDB Connection ────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=ai_diet_planner

# ── Spoonacular API (meal plan generation via Spoonacular) ────────────────────
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# ── OpenRouter API (AI chat, weekly plan generation) ──────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── JWT Secret (for auth token signing) ───────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_random_jwt_secret_key_here

# ── SMTP Email Configuration (for meal reminders) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_NAME=NutriAI Diet Planner

# ── FastAPI Port (optional) ───────────────────────────────────────────────────
PORT=8000
