# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/
*.local
.cache/

# ── Environment / Secrets ─────────────────────────────────────────────────────
# Never commit the real .env — use .env.example instead
.env
!.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── MongoDB data directory ────────────────────────────────────────────────────
# Local data dir — never commit database files
data/

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Temp / Test scripts ───────────────────────────────────────────────────────
tmp/
*.ps1
test_*.json
test_*.py

# ── Python packaging ─────────────────────────────────────────────────────────
*.egg-info/
.eggs/
build/
*.whl
.mypy_cache/
.pytest_cache/
htmlcov/
.coverage
